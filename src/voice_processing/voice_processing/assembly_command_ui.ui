  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-color: #F3F6FB;
}
QWidget#centralwidget {
    background-color: #F3F6FB;
    font-family: &quot;Noto Sans CJK KR&quot;, &quot;Malgun Gothic&quot;, &quot;Ubuntu&quot;, sans-serif;
}
QWidget#startPage, QWidget#commandPage {
    background-color: #F3F6FB;
}
QWidget#topCard, QWidget#commandCard, QWidget#voiceCard, QWidget#statusCard {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 24px;
}
QLabel#titleLabel {
    color: #111827;
    font-size: 34px;
    font-weight: 800;
}
QLabel#subTitleLabel, QLabel#hintLabel {
    color: #64748B;
    font-size: 17px;
}
QPushButton#startButton {
    background-color: #2563EB;
    color: white;
    font-size: 30px;
    font-weight: 800;
    border: none;
    border-radius: 32px;
}
QPushButton#startButton:hover {
    background-color: #1D4ED8;
}
QPushButton#startButton:pressed {
    background-color: #1E40AF;
}
QLabel#commandTitleLabel {
    color: #64748B;
    font-size: 16px;
    font-weight: 700;
}
QLabel#commandLabel {
    color: #0F172A;
    font-size: 34px;
    font-weight: 900;
}
QLabel#voiceTitleLabel, QLabel#statusTitleLabel {
    color: #334155;
    font-size: 19px;
    font-weight: 800;
}
QTextEdit#voiceText {
    background-color: #F8FAFC;
    color: #0F172A;
    border: 1px solid #E2E8F0;
    border-radius: 14px;
    padding: 12px;
    font-size: 18px;
    line-height: 140%;
}
QTextEdit#statusText {
    background-color: #0F172A;
    color: #E5E7EB;
    border: 1px solid #1E293B;
    border-radius: 14px;
    padding: 12px;
    font-size: 17px;
    font-family: &quot;Ubuntu Mono&quot;, &quot;Consolas&quot;, monospace;
    line-height: 135%;
}
QPushButton#selectButton {
    background-color: #16A34A;
    color: white;
    font-size: 17px;
    font-weight: 800;
    border: none;
    border-radius: 14px;
}
QPushButton#selectButton:hover {
    background-color: #15803D;
}
QPushButton#cancelButton {
    background-color: #E2E8F0;
    color: #334155;
    font-size: 17px;
    font-weight: 800;
    border: none;
    border-radius: 14px;
}
QPushButton#cancelButton:hover {
    background-color: #CBD5E1;
}
QPushButton#selectButton:disabled, QPushButton#cancelButton:disabled {
    background-color: #F1F5F9;
    color: #CBD5E1;
    border: 1px solid #E2E8F0;
}
QPushButton#selectButton:disabled:hover, QPushButton#cancelButton:disabled:hover {
    background-color: #F1F5F9;
}</string>
